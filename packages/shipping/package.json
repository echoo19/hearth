{
  "name": "@hearth/shipping",
  "version": "1.3.0",
  "description": "Hearth ship-your-game tooling: Electron shell generator and zip packaging helper (Node-only)",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electron/packager": "^20.0.2",
    "png2icons": "^2.0.1"
  },
  "devDependencies": {
    "@hearth/core": "*"
  }
}
