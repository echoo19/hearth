{
  "name": "@hearth/runtime",
  "version": "1.2.1",
  "description": "Hearth 2D runtime: scene instantiation, game loop, input, collision, scripting, rendering",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pixi": {
      "types": "./dist/pixi/index.d.ts",
      "default": "./dist/pixi/index.js"
    }
  },
  "files": [
    "dist",
    "player"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:player",
    "build:player": "node scripts/build-player.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hearth/core": "*",
    "wasmoon": "^1.16.0"
  },
  "peerDependencies": {
    "pixi.js": "^8.6.0"
  },
  "peerDependenciesMeta": {
    "pixi.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "pixi.js": "^8.6.0"
  }
}
