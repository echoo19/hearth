{
  "name": "@hearth/playtest",
  "version": "1.3.4",
  "description": "Hearth headless playtest tools: simulated runs, assertions, input scripts",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
