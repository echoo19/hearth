    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hearth/core": "*",
    "@hearth/runtime": "*"
  },
  "optionalDependencies": {
    "playwright-core": "^1.61.1"
  }
}
