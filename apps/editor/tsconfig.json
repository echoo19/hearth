{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@hearth/core": ["../../packages/core/src/index.ts"],
      "@hearth/core/node": ["../../packages/core/src/node/index.ts"],
      "@hearth/runtime": ["../../packages/runtime/src/index.ts"],
      "@hearth/runtime/pixi": ["../../packages/runtime/src/pixi/index.ts"],
      "@hearth/runtime/lua": ["../../packages/runtime/src/lua.ts"],
      "@hearth/runtime/ui": ["../../packages/runtime/src/ui.ts"],
      "@hearth/playtest": ["../../packages/playtest/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts", "server", "tests", "electron"]
}
