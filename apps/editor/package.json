{
  "name": "@hearth/editor",
  "version": "0.14.0",
  "description": "Hearth desktop editor (Tauri + React). Also runs in the browser via `npm run dev`.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "app:bundle": "node scripts/build-electron.mjs",
    "app": "npm run build && npm run app:bundle && electron .",
    "app:dev": "npm run app:bundle && ELECTRON_START_URL=http://localhost:5173 electron .",
    "app:dist": "npm run build && npm run app:bundle && node scripts/assemble-app.mjs && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "app:dist:installers": "npm run build && npm run app:bundle && node scripts/assemble-app.mjs && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "tauri": "tauri"
  },
  "build": {
    "appId": "dev.hearth.editor",
    "productName": "Hearth",
    "electronVersion": "33.4.11",
    "directories": {
      "app": "release-app",
      "output": "release",
      "buildResources": "buildResources"
    },
    "afterPack": "scripts/afterPack.cjs",
    "asar": true,
    "asarUnpack": [
      "dist-electron/hearth-cli.mjs",
      "dist-electron/hearth-mcp.mjs",
      "dist-electron/hearth-player.js",
      "node_modules/@lydell/node-pty/**",
      "node_modules/@lydell/node-pty-*/**"
    ],
    "npmRebuild": false,
    "artifactName": "Hearth-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "buildResources/entitlements.mac.plist",
      "entitlementsInherit": "buildResources/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@hearth/core": "*",
    "@hearth/runtime": "*",
    "@hearth/shipping": "*",
    "@hearth/templates": "*",
    "@johnnymorganz/stylua": "^2.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dockview-react": "^7.0.2",
    "pixi.js": "^8.6.0",
    "prettier": "^3.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wasmoon": "^1.16.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "vite": "^6.0.7"
  }
}
